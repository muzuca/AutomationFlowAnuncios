# arquivo: .gitignore
# descricao: protege o repositório contra o versionamento de credenciais, ambientes locais, arquivos temporários, mídias operacionais, binários dependentes da máquina e artefatos de execução que não devem subir para o GitHub.

# =============================================================================
# Credenciais e segredos
# =============================================================================
.env
.env.*
!.env.example


# =============================================================================
# Python & ambientes
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
env/
ENV/


# =============================================================================
# Ferramentas / IDE
# =============================================================================
.vscode/
.idea/
*.code-workspace


# =============================================================================
# Logs e histórico
# =============================================================================
*.log
historico_roteiros.json
historico/


# =============================================================================
# Mídia operacional e arquivos pesados
# =============================================================================
*.mp4
*.mov
*.avi
*.jpg
*.jpeg
*.png
*.webp


# =============================================================================
# Pastas locais de trabalho
# =============================================================================
produtos/
downloads/
output/
temp/
ocr_debug/


# =============================================================================
# Binários e drivers locais
# =============================================================================
*.exe
chromedriver
ffmpeg
ffprobe


# =============================================================================
# Sistema operacional
# =============================================================================
Thumbs.db
desktop.ini
.DS_Store