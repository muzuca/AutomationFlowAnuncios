# arquivo: .gitignore
# descricao: protege o repositório contra credenciais, logs de execução, capturas de tela de debug e mídias geradas.

# =============================================================================
# Credenciais e segredos
# =============================================================================
.env
.env.*
!.env.example


# =============================================================================
# Python & ambientes
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
env/
ENV/


# =============================================================================
# Ferramentas / IDE
# =============================================================================
.vscode/
.idea/
*.code-workspace


# =============================================================================
# Logs e histórico (ATUALIZADO)
# =============================================================================
*.log
*.txt
execucao.txt
log_execucao.txt
historico_roteiros.json
historico/
logs/


# =============================================================================
# Mídia operacional e arquivos pesados (MANTIDO)
# =============================================================================
*.mp4
*.mov
*.avi
*.jpg
*.jpeg
*.png
*.webp


# =============================================================================
# Pastas locais de trabalho
# =============================================================================
produtos/
downloads/
output/
temp/
ocr_debug/


# =============================================================================
# Binários e drivers locais
# =============================================================================
*.exe
*.bat
*.ps1
chromedriver
ffmpeg
ffprobe


# =============================================================================
# Sistema operacional
# =============================================================================
Thumbs.db
desktop.ini
.DS_Store